# IMSDA Registration PWA — deploy secrets.
#
# Copy this file to "deploy.secrets" (which is gitignored) and fill in real
# values, then run ./deploy.sh. Do NOT commit deploy.secrets.
#
#   cp deploy.secrets.example deploy.secrets
#   nano deploy.secrets
#   ./deploy.sh

# Shared secret between this PWA and the Google Apps Script web app.
WR26_GAS_SECRET="replace-with-gas-shared-secret"

# Signs staff session cookies. Use a long random value, e.g.:
#   openssl rand -hex 32
SESSION_SECRET="replace-with-random-64-char-hex"

# Bootstrap admin accounts (always work even if the Staff sheet is empty).
# Passwords MUST be bcrypt hashes, not plaintext. Generate an account with:
#   node pwa-server/add-user.js --user caleb --role admin --print
# then paste the single-line value it prints below.
WR26_AUTH_USERS='[{"username":"caleb","password":"$2b$10$replace.with.a.real.bcrypt.hash.value.0000000000000000000","roles":["admin"]}]'

# Optional — Square pay-later webhook. Leave blank to disable the webhook.
SQUARE_WEBHOOK_SIGNATURE_KEY=""
SQUARE_WEBHOOK_NOTIFICATION_URL=""

# Optional non-secret overrides (defaults are set in deploy.sh):
# WR26_GAS_URL="https://script.google.com/macros/s/XXXX/exec"
# PORT="3001"
# TRUST_PROXY="1"
