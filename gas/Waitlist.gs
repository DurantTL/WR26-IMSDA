function writeWaitlistEntry(d){try{getSS().getSheetByName('Waitlist').appendRow([d.waitlistId,new Date(),d.firstName,d.lastName,d.email,d.phone,d.church,d.ffEntryId,'waiting',d.position,'',d.notes||'']);return {success:true};}catch(e){return {success:false,message:e.message};}}
function getWaitlist(){var rows=getSS().getSheetByName('Waitlist').getDataRange().getValues().slice(1);return {success:true,waitlist:rows.map(function(r){return {waitlistId:r[0],timestamp:r[1],firstName:r[2],lastName:r[3],email:r[4],phone:r[5],church:r[6],ffEntryId:r[7],status:r[8],position:r[9],promotedAt:r[10],notes:r[11]};}).filter(function(w){return w.status==='waiting'||w.status==='promoted';})};}
function getWaitlistPosition(){var rows=getSS().getSheetByName('Waitlist').getDataRange().getValues().slice(1);return rows.filter(function(r){return r[8]==='waiting';}).length+1;}
function promoteWaitlist(waitlistId,adminUser,editPageUrl){try{return withScriptLock_(function(){var cap=checkCapacity();if(cap.available<1)return {success:false,message:'No spots available'};var s=getSS().getSheetByName('Waitlist');var v=s.getDataRange().getValues();for(var i=1;i<v.length;i++){if(String(v[i][0])===String(waitlistId)&&v[i][8]==='waiting'){var wr={registrationId:generateRegistrationId(),firstName:v[i][2],lastName:v[i][3],email:v[i][4],phone:v[i][5],church:v[i][6],arrivalDate:'',departureDate:'',dietaryNeeds:'',emergencyContactName:'',emergencyContactPhone:'',specialNeeds:'',promoCode:'',discountAmount:0,originalAmount:0,finalAmount:0,paymentMethod:'waitlist_promotion',paymentStatus:'promoted_from_waitlist',squarePaymentId:'',ffEntryId:v[i][7],status:'active',transferNotes:'',checkedIn:false,checkInTime:'',checkInBy:'',qrToken:Utilities.getUuid(),editToken:Utilities.getUuid(),adminNotes:'Promoted from waitlist by '+adminUser};var r=writeRegistration(wr);if(!r.success)return r;s.getRange(i+1,9).setValue('promoted');s.getRange(i+1,11).setValue(new Date());sendWaitlistPromotionEmail({firstName:v[i][2],email:v[i][4],position:v[i][9]},wr,editPageUrl||getConfig().EDIT_PAGE_URL);return {success:true,newRegistrationId:wr.registrationId};}}return {success:false,message:'Waitlist entry not found'};});}catch(e){return {success:false,message:e.message};}}
function removeWaitlist(waitlistId,adminUser){try{var s=getSS().getSheetByName('Waitlist');var v=s.getDataRange().getValues();for(var i=1;i<v.length;i++){if(String(v[i][0])===String(waitlistId)){s.getRange(i+1,9).setValue('removed');var note=String(v[i][11]||'');var audit='['+formatDate(new Date())+'] Removed by '+String(adminUser||'unknown');s.getRange(i+1,12).setValue(note?note+'\n'+audit:audit);v[i][8]='removed';break;}}var p=1;for(i=1;i<v.length;i++){if(v[i][8]==='waiting'){s.getRange(i+1,10).setValue(p++);}}return {success:true};}catch(e){return {success:false,message:e.message};}}
function autoPromoteWaitlist(edit_page_url){var wl=getWaitlist();if(!wl.success)return wl;var next=(wl.waitlist||[]).filter(function(x){return x.status==='waiting';}).sort(function(a,b){return a.position-b.position;})[0];if(!next)return {success:true,message:'No waiting entries'};return promoteWaitlist(next.waitlistId,'system',edit_page_url);}
