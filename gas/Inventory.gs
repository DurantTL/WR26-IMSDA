function getAvailability(){try{var hs=getSS().getSheetByName('Housing').getDataRange().getValues();var regs=getAllRegistrations({status:'active'});var housing=hs.slice(1).map(function(r){var id=r[0],unlim=String(r[8]).toUpperCase()==='TRUE';var used=regs.filter(function(x){return x.housingOption===id||x.housingOption===r[1];}).length;var cap=Number(r[3]||0);var avail=unlim?'∞':Math.max(cap-used,0);return {optionId:id,optionName:r[1],pricePerNight:Number(r[2]||0),totalCapacity:cap,available:avail,isUnlimited:unlim,minNights:Number(r[9]||0),description:r[10],status:r[11]||'active'};});return {success:true,housing:housing};}catch(e){return {success:false,message:e.message};}}
function checkCapacity(){var c=getConfig();var active=getAllRegistrations({status:'active'}).length;return {total:Number(c.CAPACITY||350),registered:active,available:Math.max(Number(c.CAPACITY||350)-active,0),waitlistEnabled:true};}
