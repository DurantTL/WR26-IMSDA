function bccObj(){var b=getConfig().NOTIFICATION_EMAIL;return b?{bcc:b}:{};}
function sendConfirmationEmail(reg,edit){var sub="Women's Retreat 2026 – Registration Confirmed!";var body='<p>Hello '+reg.firstName+',</p><p>Your registration is complete.</p><p><b>Name:</b> '+reg.firstName+' '+reg.lastName+'<br><b>Church:</b> '+reg.church+'<br><b>Arrival:</b> '+reg.arrivalDate+'<br><b>Departure:</b> '+reg.departureDate+'<br><b>Amount Paid:</b> $'+reg.finalAmount+'</p>'+(Number(reg.discountAmount)>0?'<p>Promo savings: $'+reg.discountAmount+'</p>':'')+'<p><a href="'+edit+'?token='+reg.editToken+'">Edit Registration</a></p><p><img src="'+generateQRUrl(reg.qrToken)+'"/></p><p>Show this QR code at check-in.</p><p>IMSDA</p>';MailApp.sendEmail(Object.assign({to:reg.email,subject:sub,htmlBody:body},bccObj()));}
function sendWaitlistEmail(w){MailApp.sendEmail(Object.assign({to:w.email,subject:"Women's Retreat 2026 – You're on the Waitlist",htmlBody:'<p>You are currently #'+w.position+' on the waitlist. No payment will be charged until promoted.</p>'},bccObj()));}
function sendWaitlistPromotionEmail(w,n,edit){MailApp.sendEmail(Object.assign({to:n.email,subject:"Women's Retreat 2026 – Your Spot is Confirmed!",htmlBody:'<p>Great news! A spot opened up.</p><p>'+n.firstName+' '+n.lastName+'</p><p><a href="'+edit+'?token='+n.editToken+'">Edit Registration</a></p><p><img src="'+generateQRUrl(n.qrToken)+'"/></p>'},bccObj()));}
function sendTransferEmail(o,n,reason,refund,edit){var sub="Women's Retreat 2026 – Registration Transfer Confirmation";MailApp.sendEmail(Object.assign({to:o.email,subject:sub,htmlBody:'<p>Your registration has been transferred out.</p><p>Reason: '+(reason||'')+'</p><p>Refund notes: '+(refund||'')+'</p>'},bccObj()));MailApp.sendEmail(Object.assign({to:n.email,subject:sub,htmlBody:'<p>Your transfer registration is confirmed.</p><p><a href="'+edit+'?token='+n.editToken+'">Edit Registration</a></p><p><img src="'+generateQRUrl(n.qrToken)+'"/></p>'},bccObj()));}
function sendEditConfirmationEmail(reg){MailApp.sendEmail(Object.assign({to:reg.email,subject:"Women's Retreat 2026 – Registration Updated",htmlBody:'<p>Your registration details were updated.</p><p>'+reg.firstName+' '+reg.lastName+' | '+reg.church+'</p>'},bccObj()));}
